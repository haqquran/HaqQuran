rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true);
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'HaqQuran@gmail.com' || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) 
        && data.keys().size() <= 15
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && data.createdAt == request.time
        && (data.username == null || (data.username is string && data.username.size() <= 32))
        && (data.firstName == null || (data.firstName is string && data.firstName.size() <= 50))
        && (data.lastName == null || (data.lastName is string && data.lastName.size() <= 50))
        && (data.subtitle == null || (data.subtitle is string && data.subtitle.size() <= 100))
        && (data.coverURL == null || (data.coverURL is string && data.coverURL.size() <= 1024))
        && (data.socialLinks == null || data.socialLinks is map)
        && (!data.keys().hasAny(['isAdmin']) || data.isAdmin == false || isAdmin());
    }

    function isValidPost(data) {
      return data.keys().hasAll(['userId', 'content', 'createdAt'])
        && data.keys().size() <= 12
        && data.userId == request.auth.uid
        && data.content is string && data.content.size() <= 5000
        && data.createdAt == request.time
        && (data.imageUrl == null || (data.imageUrl is string && data.imageUrl.size() <= 1024))
        && (data.reportCount == null || data.reportCount is int);
    }

    function isValidComment(data) {
      return data.keys().hasAll(['postId', 'userId', 'content', 'createdAt'])
        && data.keys().size() <= 7
        && data.userId == request.auth.uid
        && data.content is string && data.content.size() <= 1000
        && data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidUser(incoming());
      allow update: if isVerified() && (isOwner(userId) || isAdmin())
        && incoming().diff(existing()).affectedKeys().hasOnly([
          'displayName', 'photoURL', 'bio', 'isAdmin', 
          'firstName', 'lastName', 'username', 'subtitle', 'coverURL', 'socialLinks'
        ])
        && incoming().uid == existing().uid;
    }

    match /posts/{postId} {
      allow get: if true;
      allow list: if true; 
      allow create: if isVerified() && isValidId(postId) && isValidPost(incoming());
      allow update: if isVerified() && (
        (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'imageUrl', 'hashtags']))
        || (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount', 'commentsCount', 'reportCount']))
        || isAdmin()
      );
      allow delete: if isVerified() && (isOwner(existing().userId) || isAdmin());

      match /comments/{commentId} {
        allow list: if true;
        allow create: if isVerified() && isValidId(commentId) && isValidComment(incoming())
          && exists(/databases/$(database)/documents/posts/$(postId));
        allow delete: if isVerified() && (
          isOwner(existing().userId) 
          || isAdmin()
          || (exists(/databases/$(database)/documents/posts/$(postId)) && get(/databases/$(database)/documents/posts/$(postId)).data.userId == request.auth.uid)
        );
      }

      match /likes/{userId} {
        allow get: if isSignedIn();
        allow create: if isVerified() && userId == request.auth.uid
          && exists(/databases/$(database)/documents/posts/$(postId));
        allow delete: if isVerified() && isOwner(userId);
      }

      match /reports/{userId} {
        allow create: if isVerified() && userId == request.auth.uid
          && exists(/databases/$(database)/documents/posts/$(postId));
      }
    }

    match /users/{userId}/bookmarks/{bookmarkId} {
      allow read, write: if isVerified() && isOwner(userId);
    }
  }
}
